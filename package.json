{
  "name": "mcp-demo-cloudflare",
  "version": "1.0.0",
  "description": "A two-part MCP demo: mock MCP server (Streamable HTTP) and Cloudflare Workers client",
  "type": "module",
  "scripts": {
    "dev:server": "cd packages/mcp-server && wrangler dev",
    "dev:client": "cd packages/workers-client && wrangler dev",
    "dev:ai": "cd packages/ai-gateway && wrangler dev",
    "deploy:server": "cd packages/mcp-server && wrangler deploy",
    "deploy:client": "cd packages/workers-client && wrangler deploy",
    "deploy:ai": "cd packages/ai-gateway && wrangler deploy",
    "tail:server": "cd packages/mcp-server && wrangler tail",
    "tail:client": "cd packages/workers-client && wrangler tail",
    "tail:ai": "cd packages/ai-gateway && wrangler tail",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "echo 'Start servers first: npm run dev:server & npm run dev:client' && npx vitest run --config vitest.integration.config.ts"
  },
  "workspaces": [
    "packages/*"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "cloudflare",
    "workers",
    "ai",
    "demo",
    "agents"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250321.0",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0",
    "wrangler": "^4.0.0"
  },
  "dependencies": {
    "@cloudflare/codemode": "^0.3.4",
    "@modelcontextprotocol/sdk": "^1.8.0",
    "agents": "^0.10.0",
    "zod": "^4.0.0"
  }
}
